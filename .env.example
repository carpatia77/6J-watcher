# 6J Watcher — Environment Variables
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env real — ele esta no .gitignore.

# Databento API Key (obrigatoria para backtest historico MBP-10)
# Obtenha em: https://app.databento.com/portal/keys
DATABENTO_API_KEY=

# NVIDIA API Key (obrigatoria para integracao LLM)
# Obtenha em: https://build.nvidia.com/
NVIDIA_API_KEY=
